# ─── Cohere API ─────────────────────────────────────────────────────────────
CohereAPIKey=your_cohere_api_key_here

# ─── Gmail Account 1 ────────────────────────────────────────────────────────
GMAIL_USER1=your_email_account1@gmail.com
GMAIL_PASS1=your_app_password_1_here

# ─── Gmail Account 2 ────────────────────────────────────────────────────────
GMAIL_USER2=your_email_account2@gmail.com
GMAIL_PASS2=your_app_password_2_here

# NOTE: Use Gmail App Passwords (not your main password).
# Enable 2FA, then generate from: myaccount.google.com/apppasswords
